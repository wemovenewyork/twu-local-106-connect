generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  divisionId         String?   @map("division_id")
  subUnitId          String?   @map("sub_unit_id")
  role               UserRole  @default(member)
  language           String    @default("en")
  avatarUrl          String?   @map("avatar_url")
  verified           Boolean   @default(false)
  emailVerifyToken   String?   @map("email_verify_token")
  emailVerifyExpires DateTime? @map("email_verify_expires")
  flexibleMode       Boolean   @default(false) @map("flexible_mode")
  flexibleSince      DateTime? @map("flexible_since")
  invitedBy          String?   @map("invited_by")
  termsAcceptedAt    DateTime? @map("terms_accepted_at")
  termsVersion       String?   @map("terms_version")
  loginAttempts      Int       @default(0) @map("login_attempts")
  lockedUntil        DateTime? @map("locked_until")
  suspendedUntil     DateTime? @map("suspended_until")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  division           Division?          @relation(fields: [divisionId], references: [id])
  subUnit            SubUnit?           @relation(fields: [subUnitId], references: [id], onDelete: SetNull)
  inviter            User?              @relation("Invites", fields: [invitedBy], references: [id])
  invitees           User[]             @relation("Invites")
  swaps              Swap[]
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  reputation         Reputation?
  reviewsGiven       Review[]           @relation("ReviewsGiven")
  reviewsReceived    Review[]           @relation("ReviewsReceived")
  reports            Report[]
  pushSubscriptions  PushSubscription[]
  agreementsAsA      SwapAgreement[]    @relation("AgreementUserA")
  agreementsAsB      SwapAgreement[]    @relation("AgreementUserB")
  announcements      Announcement[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  savedSwaps         SavedSwap[]
  blocksGiven        Block[]            @relation("BlocksGiven")
  blocksReceived     Block[]            @relation("BlocksReceived")
  newsAuthored       News[]             @relation("NewsAuthor")
  newsReviewed       News[]             @relation("NewsReviewer")
  documentsUploaded  Document[]         @relation("DocumentUploader")
  documentsOwned     Document[]         @relation("DocumentOwner")
  pagesAuthored      Page[]             @relation("PageAuthor")
  notificationPreference NotificationPreference?
  registrationApproval        RegistrationApproval?
  registrationsReviewed       RegistrationApproval[] @relation("RegistrationReviewer")
  overtimeRequests       OvertimeRequest[]      @relation("OvertimeRequestSubmitter")
  lastActiveAt       DateTime?          @map("last_active_at")
  jobTitle           String?            @map("job_title")
  divisionSetAt      DateTime?          @map("division_set_at")
  verifiedMember     Boolean            @default(false) @map("verified_member")
  dispatcherVerified Boolean            @default(false) @map("dispatcher_verified")
  dispatcherBadge    String?            @map("dispatcher_badge")

  @@map("users")
}

model Division {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?

  users         User[]
  swaps         Swap[]
  announcements Announcement[]
  subUnits      SubUnit[]
  news          News[]
  documents     Document[]
  officers      Officer[]              @relation("OfficerDivision")
  declaredRegistrations RegistrationApproval[] @relation("DeclaredDivision")
  assignedRegistrations RegistrationApproval[] @relation("AssignedDivision")

  @@map("divisions")
}

model SubUnit {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  divisionId  String   @map("division_id")
  division    Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  users       User[]
  swaps       Swap[]
  documents   Document[]
  declaredRegistrations RegistrationApproval[] @relation("DeclaredSubUnit")
  assignedRegistrations RegistrationApproval[] @relation("AssignedSubUnit")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sub_units")
  @@index([divisionId])
}

model Announcement {
  id         String    @id @default(uuid())
  divisionId String    @map("division_id")
  authorId   String    @map("author_id")
  body       String    @db.VarChar(600)
  pinned     Boolean   @default(false)
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model Swap {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  divisionId   String       @map("division_id")
  subUnitId    String?      @map("sub_unit_id")
  category     SwapCategory
  status       SwapStatus   @default(open)
  date         DateTime?    @db.Date
  details      String       @db.VarChar(500)
  contact      String?
  run          String?
  route        String?
  startTime    String?      @map("start_time")
  clearTime    String?      @map("clear_time")
  swingStart   String?      @map("swing_start")
  swingEnd     String?      @map("swing_end")
  fromDay      String?      @map("from_day")
  fromDate     DateTime?    @map("from_date") @db.Date
  toDay        String?      @map("to_day")
  toDate       DateTime?    @map("to_date") @db.Date
  vacationHave String?      @map("vacation_have")
  vacationWant String?      @map("vacation_want")
  posterName   String       @map("poster_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id])
  division   Division        @relation(fields: [divisionId], references: [id])
  subUnit    SubUnit?        @relation(fields: [subUnitId], references: [id], onDelete: SetNull)
  messages   Message[]
  reviews    Review[]
  reports    Report[]
  agreements SwapAgreement[]
  savedBy    SavedSwap[]

  @@index([divisionId, status, createdAt(sort: Desc)])
  @@map("swaps")
}

model SavedSwap {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  swapId    String   @map("swap_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  swap      Swap     @relation(fields: [swapId], references: [id], onDelete: Cascade)

  @@unique([userId, swapId])
  @@index([userId])
  @@map("saved_swaps")
}

model Message {
  id         String   @id @default(uuid())
  swapId     String?  @map("swap_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  text       String   @db.VarChar(2000)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  swap     Swap? @relation(fields: [swapId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser   User  @relation("ReceivedMessages", fields: [toUserId], references: [id])

  @@map("messages")
}

model Reputation {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  completed Int      @default(0)
  cancelled Int      @default(0)
  noShow    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("reputation")
}

model Review {
  id         String   @id @default(uuid())
  swapId     String   @map("swap_id")
  reviewerId String   @map("reviewer_id")
  reviewedId String   @map("reviewed_id")
  rating     Int
  createdAt  DateTime @default(now()) @map("created_at")

  swap     Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewed User @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  @@map("reviews")
}

model Report {
  id         String       @id @default(uuid())
  swapId     String       @map("swap_id")
  reporterId String       @map("reporter_id")
  reason     String?
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now()) @map("created_at")

  swap     Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  reporter User @relation(fields: [reporterId], references: [id])

  @@map("reports")
}

model SwapAgreement {
  id          String          @id @default(uuid())
  swapId      String          @map("swap_id")
  userAId     String          @map("user_a_id")
  userBId     String          @map("user_b_id")
  status      AgreementStatus @default(pending)
  userANote   String?         @map("user_a_note") @db.VarChar(500)
  userBNote   String?         @map("user_b_note") @db.VarChar(500)
  userAAt     DateTime?       @map("user_a_at")
  userBAt     DateTime?       @map("user_b_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  swap  Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  userA User @relation("AgreementUserA", fields: [userAId], references: [id])
  userB User @relation("AgreementUserB", fields: [userBId], references: [id])

  // Raw SQL partial unique index — NOT representable in Prisma DSL.
  // Defined in migration 20260414_agreement_unique_active:
  //   CREATE UNIQUE INDEX "swap_agreements_swap_id_active_key"
  //   ON "swap_agreements" ("swap_id") WHERE status IN ('pending', 'userA_confirmed')
  // DO NOT drop this index — it prevents race-condition duplicate agreements.
  @@map("swap_agreements")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

enum SwapCategory {
  work
  daysoff
  vacation
  open_work
}

enum SwapStatus {
  open
  pending
  filled
  expired
}

enum ReportStatus {
  pending
  reviewed
  dismissed
}

enum UserRole {
  member
  contributor
  editor
  divisionAdmin
  localAdmin
  superAdmin
}

enum AgreementStatus {
  pending
  userA_confirmed
  completed
  cancelled
}

model Block {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String
  targetId   String?  @map("target_id")
  targetType String?  @map("target_type")
  detail     String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

enum AuditAction {
  role_change
  report_dismiss
  report_review
  user_delete
  account_delete
}

enum NewsStatus {
  draft
  inReview
  published
  archived
}

model News {
  id          String     @id @default(cuid())
  title       String
  body        String
  status      NewsStatus @default(draft)
  divisionId  String?    @map("division_id")
  division    Division?  @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  authorId    String     @map("author_id")
  author      User       @relation("NewsAuthor", fields: [authorId], references: [id])
  reviewerId  String?    @map("reviewer_id")
  reviewer    User?      @relation("NewsReviewer", fields: [reviewerId], references: [id])

  publishedAt DateTime?  @map("published_at")
  publiclyVisible Boolean @default(false) @map("publicly_visible")
  publicSlug      String? @unique @map("public_slug")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("news")
  @@index([divisionId])
  @@index([status])
  @@index([publishedAt])
  @@index([publiclyVisible])
}

enum DocumentVisibility {
  all
  division
  subUnit
  selfOnly
}

enum DocumentType {
  contract     // CBAs, contract amendments, MOAs
  form         // HR forms, pension forms, benefit forms
  constitution // Union constitution, bylaws
  memo         // Memos, letters, announcements
  other        // Default catchall
}

model Document {
  id          String             @id @default(cuid())
  title       String
  description String?
  fileUrl     String             @map("file_url")
  fileSize    Int?               @map("file_size")
  mimeType    String?            @map("mime_type")

  visibility  DocumentVisibility @default(division)
  documentType DocumentType      @default(other) @map("document_type")
  divisionId  String?            @map("division_id")
  division    Division?          @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  subUnitId   String?            @map("sub_unit_id")
  subUnit     SubUnit?           @relation(fields: [subUnitId], references: [id], onDelete: SetNull)
  ownerUserId String?            @map("owner_user_id")
  owner       User?              @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  uploaderId  String             @map("uploader_id")
  uploader    User               @relation("DocumentUploader", fields: [uploaderId], references: [id])

  publiclyVisible Boolean        @default(false) @map("publicly_visible")

  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("documents")
  @@index([divisionId])
  @@index([visibility])
  @@index([ownerUserId])
  @@index([publiclyVisible])
  @@index([documentType])
}

enum NotificationCategory {
  contract
  safety
  rally
  news
  benefit
  swapMatch
  systemAlert
}

enum RegistrationStatus {
  pending
  approved
  reassigned
  rejected
}

model RegistrationApproval {
  id              String             @id @default(cuid())
  userId          String             @unique @map("user_id")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  declaredDivisionId String?         @map("declared_division_id")
  declaredDivision   Division?       @relation("DeclaredDivision", fields: [declaredDivisionId], references: [id], onDelete: SetNull)
  declaredSubUnitId  String?         @map("declared_sub_unit_id")
  declaredSubUnit    SubUnit?        @relation("DeclaredSubUnit", fields: [declaredSubUnitId], references: [id], onDelete: SetNull)

  assignedDivisionId String?         @map("assigned_division_id")
  assignedDivision   Division?       @relation("AssignedDivision", fields: [assignedDivisionId], references: [id], onDelete: SetNull)
  assignedSubUnitId  String?         @map("assigned_sub_unit_id")
  assignedSubUnit    SubUnit?        @relation("AssignedSubUnit", fields: [assignedSubUnitId], references: [id], onDelete: SetNull)

  status          RegistrationStatus @default(pending)
  reviewedAt      DateTime?          @map("reviewed_at")
  reviewerId      String?            @map("reviewer_id")
  reviewer        User?              @relation("RegistrationReviewer", fields: [reviewerId], references: [id])
  rejectionReason String?            @map("rejection_reason")

  reminderSent12h Boolean            @default(false) @map("reminder_sent_12h")
  reminderSent24h Boolean            @default(false) @map("reminder_sent_24h")
  reminderSent72h Boolean            @default(false) @map("reminder_sent_72h")

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("registration_approvals")
  @@index([status])
  @@index([declaredDivisionId])
  @@index([assignedDivisionId])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  contractEnabled     Boolean  @default(true) @map("contract_enabled")
  safetyEnabled       Boolean  @default(true) @map("safety_enabled")
  rallyEnabled        Boolean  @default(true) @map("rally_enabled")
  newsEnabled         Boolean  @default(true) @map("news_enabled")
  benefitEnabled      Boolean  @default(true) @map("benefit_enabled")
  swapMatchEnabled    Boolean  @default(true) @map("swap_match_enabled")
  systemAlertEnabled  Boolean  @default(true) @map("system_alert_enabled")

  pushEnabled         Boolean  @default(true) @map("push_enabled")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt      @map("updated_at")

  @@map("notification_preferences")
}

enum OfficerScope {
  local
  division
  staff
}

model Officer {
  id                 String       @id @default(cuid())
  name               String
  title              String
  scope              OfficerScope
  divisionId         String?      @map("division_id")
  division           Division?    @relation("OfficerDivision", fields: [divisionId], references: [id], onDelete: SetNull)

  displayOrder       Int          @default(0) @map("display_order")

  bio                String?
  photoUrl           String?      @map("photo_url")
  contactEmail       String?      @map("contact_email")
  contactFormEnabled Boolean      @default(true) @map("contact_form_enabled")

  termStart          DateTime?    @map("term_start")
  termEnd            DateTime?    @map("term_end")

  active             Boolean      @default(true)

  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt      @map("updated_at")

  @@map("officers")
  @@index([scope])
  @@index([divisionId])
  @@index([active])
}

enum OvertimeRequestType {
  rdo          // regular day off (work on scheduled off-day)
  doubleShift  // extra/double shift on a working day
}

enum OvertimeRequestStatus {
  submitted
  withdrawn
  acknowledged // assignment desk has seen it (manual marker; not yet wired)
}

model OvertimeRequest {
  id             String                @id @default(cuid())
  submitterId    String                @map("submitter_id")
  submitter      User                  @relation("OvertimeRequestSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)

  // Payroll number is captured per-request, not stored on User identity.
  // Storing payroll numbers centrally would create a PII honeypot;
  // per-submission means a DB compromise leaks only the submissions
  // (not a master payroll directory).
  payrollNumber  String                @map("payroll_number")

  requestedDate  DateTime              @map("requested_date") @db.Date
  type           OvertimeRequestType
  preferences    String?               // free-text, capped at 500 chars by API

  status         OvertimeRequestStatus @default(submitted)
  withdrawnAt    DateTime?             @map("withdrawn_at")
  acknowledgedAt DateTime?             @map("acknowledged_at")
  acknowledgedById String?             @map("acknowledged_by_id")

  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt      @map("updated_at")

  @@map("overtime_requests")
  @@index([submitterId])
  @@index([requestedDate])
  @@index([status])
}

model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  body            String
  metaDescription String?   @map("meta_description")
  published       Boolean   @default(false)
  publishedAt     DateTime? @map("published_at")

  authorId        String    @map("author_id")
  author          User      @relation("PageAuthor", fields: [authorId], references: [id])

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  @@map("pages")
  @@index([slug])
  @@index([published])
}
